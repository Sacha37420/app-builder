# ── Adresses ─────────────────────────────────────────────────────
PORT_BACKEND=8087
BACKEND_URL=http://localhost:8087
PORT_FRONTEND=4205
FRONTEND_URL=http://localhost:4205

# ── Base de données ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devdb
DB_SCHEMA=app_builder
DB_USER=devuser
DB_PASSWORD=devpassword

# ── Django ───────────────────────────────────────────────────────
SECRET_KEY=REDACTED-SECRET-ROTATED
DEBUG=False
ALLOWED_HOSTS=*

# ── Reverse proxy (Caddy) ────────────────────────────────────────
SCRIPT_NAME=/app-builder-api

# ── SSO Keycloak ─────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=app-builder
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ssolab
# Client public (SPA Angular) — Keycloak → Clients → app-builder → Access type : Public
# Valid redirect URIs : http://localhost:4205/*

# ── URLs (propagées automatiquement par reset_url.sh) ────────────
PORT_KEYCLOAK=8080
SERVER_URL_LAN=http://192.168.1.X
SERVER_URL_WAN=http://VOTRE_IP_WAN
KEYCLOAK_URL=http://192.168.1.X:8080
KEYCLOAK_PUBLIC_URL=http://VOTRE_IP_WAN:8080

# ── Clés API pour le chat IA ──────────────────────────────────────────────────
# Fournir au moins l'une des deux clés ; l'utilisateur choisit le provider dans l'UI
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME
